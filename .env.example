# bingx-agent root environment example
# Copy to .env on the server and fill only on the server. Never commit real secrets.

# Runtime source-of-truth path
DATA_DIR=/var/www/vhosts/ob-gate.com/httpdocs
BINGX_AGENT_DIR=/var/www/vhosts/ob-gate.com/httpdocs

# Scheduler/runtime
ENABLE_RUN_CYCLE=1
DERIV_HISTORY_SCHED_ENABLED=1
VOL_SCHED_ENABLED=1
CYCLE_SCHED_ENABLED=1
CYCLE_SCHED_INTERVAL_MS=300000
CYCLE_SCHED_MODE=NO_NEWS

# Public/API
PUBLIC_BASE_URL=https://api.ob-gate.com
OBGATE_BASE_URL=https://api.ob-gate.com
OBGATE_SYMBOL=BTC-USDT

# Server-side secrets. Set real values only on the server.
AUTH_COOKIE_SECRET=<SET_ON_SERVER>
AUTH_PASSWORD_HASH=<SET_ON_SERVER>
ADMIN_KEY=<SET_ON_SERVER>
INTERNAL_API_KEY=<SET_ON_SERVER>
RUN_CYCLE_TRIGGER_KEY=<SET_ON_SERVER>
REFRESH_ENDPOINT_KEY=<SET_ON_SERVER>
OBGATE_TRIGGER_KEY=<SET_ON_SERVER>
SM_TICK_KEY=<SET_ON_SERVER>
TRADINGECON_USER=<SET_ON_SERVER>
TRADINGECON_KEY=<SET_ON_SERVER>

# Safety flags. Keep blocked until operator evidence is complete.
LIVE_TRADING_ENABLED=false
ENABLE_ORDER_PLACEMENT=false
PRODUCTION_TRADING_READY=false
EXCHANGE_MANUAL_APPROVAL=not_approved

# Paper trading runner (external execution-runner). Paper-only; never enables live trading.
# Leave false until paper liveness is verified. Enabling this only affects PAPER simulation.
PAPER_TRADING_ENABLED=false
# Root directory for paper execution audit .jsonl files. Falls back to BINGX_AGENT_DIR if unset.
# Reader resolves: EXECUTION_AUDIT_ROOT_DIR -> BINGX_AGENT_DIR -> <cwd>/tmp
EXECUTION_AUDIT_ROOT_DIR=/var/www/vhosts/ob-gate.com/httpdocs
