# ============================================================
# bingx-agent Dashboard — .env.local.example
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real values.
# ============================================================

# -------------------------------------------------------
# PRODUCTION SAFETY FLAGS (Phase E — Production Hardening)
# อย่าเปลี่ยนค่าเหล่านี้เป็น true จนกว่าจะผ่านทุก gate
# -------------------------------------------------------

# Live Trading: ห้ามเปิดจนกว่าจะผ่าน paper trading gate ครบ
LIVE_TRADING_ENABLED=false

# Order Placement: ห้าม place real order จนกว่าจะผ่าน live migration gate
ENABLE_ORDER_PLACEMENT=false

# Trading Safety Mode: readonly = monitor only, no order actions
TRADING_SAFETY_MODE=readonly

# Paper Trading: ยังไม่ confirmed — ตั้งเป็น not_confirmed
# เปลี่ยนเป็น true เมื่อผ่าน canary paper trading phase เท่านั้น
PAPER_TRADING_ENABLED=not_confirmed

# Production Ready: flag รวม — ต้องผ่าน all gates ก่อน
PRODUCTION_TRADING_READY=false

# -------------------------------------------------------
# SOURCE OF TRUTH: root directory ของ bingx-agent runtime
# readLatest.ts และ /api/plan-status อ่านจากที่นี่เป็นหลัก
# -------------------------------------------------------
DATA_DIR=/var/www/vhosts/ob-gate.com/httpdocs
BINGX_AGENT_DIR=/var/www/vhosts/ob-gate.com/httpdocs
AGENT_DIR=/var/www/vhosts/ob-gate.com/httpdocs

# -------------------------------------------------------
# Alternative env var names (ระบบยอมรับทั้งหมด):
# -------------------------------------------------------
# DATA_DIR=/var/www/vhosts/ob-gate.com/httpdocs
# BINGX_DATA_DIR=/var/www/vhosts/ob-gate.com/httpdocs
# OBGATE_DATA_DIR=/var/www/vhosts/ob-gate.com/httpdocs

# -------------------------------------------------------
# Node.js environment
# development = verbose logs, no live order placement guard
# production  = structured logs, all safety flags enforced
# -------------------------------------------------------
NODE_ENV=development

# -------------------------------------------------------
# Dashboard runtime/API settings
# -------------------------------------------------------
POLL_MS=10000
NEXT_DISABLE_TURBOPACK=1
BINGX_AGENT_BASE_URL=https://api.ob-gate.com
NEXT_PUBLIC_API_BASE=

# -------------------------------------------------------
# Dashboard auth. Set real values only on the server.
# -------------------------------------------------------
AUTH_PASSWORD_HASH=<SET_ON_SERVER>
AUTH_COOKIE_SECRET=<SET_ON_SERVER>
AUTH_DEBUG=0
ADMIN_KEY=<SET_ON_SERVER>

# -------------------------------------------------------
# Mirror: เปิดเพื่อให้ route เขียน mirror ไป public/data/
# ปิดทั้งหมดโดย default (source of truth = root files)
# -------------------------------------------------------
# MIRROR_PLAN_STATUS_VIEW_TO_PUBLIC=true
# MIRROR_LOGS_TO_PUBLIC=true
# MIRROR_PLAN_HISTORY_TO_PUBLIC=true

# -------------------------------------------------------
# Next.js port (optional — default 3000)
# -------------------------------------------------------
# PORT=3000

# -------------------------------------------------------
# ไฟล์ที่ระบบอ่าน (ต้องอยู่ใน BINGX_AGENT_DIR):
#   market_snapshot.json    — OHLC / derivatives / session
#   latest_decision.json    — STEP01 output (regime / plan)
#   news_context.json       — news risk overlay
#   plan_status_state.json  — plan state machine
#   plan_status_log.jsonl   — plan history
# -------------------------------------------------------

# -------------------------------------------------------
# ห้าม:
#   - เอา API key / secret ใส่ที่นี่
#   - commit .env.local ขึ้น repo
#   - ตั้ง MIRROR_* = true ใน production โดยไม่เข้าใจผลกระทบ
#   - เปลี่ยน LIVE_TRADING_ENABLED=true โดยไม่ผ่าน gate
#   - เปลี่ยน PRODUCTION_TRADING_READY=true โดยไม่ผ่าน checklist
# -------------------------------------------------------

# -------------------------------------------------------
# Phase M-0 — Shadow Live / Read-only Exchange Sync Readiness
# ปิดทั้งหมดโดย default — ห้ามเปิดก่อน operator approval
# -------------------------------------------------------
SHADOW_LIVE_ENABLED=false
EXCHANGE_READONLY_SYNC_ENABLED=false

# Read-only API key สำหรับ shadow sync เท่านั้น (ไม่ใช่ trading key)
# ห้าม set ก่อนได้รับ operator approval เป็นลายลักษณ์อักษร
# ห้ามใช้ NEXT_PUBLIC_ prefix — ต้องอยู่ server-side เท่านั้น
BINGX_READONLY_API_KEY=
BINGX_READONLY_SECRET=

# Operator approval gate — ต้องตั้งเป็น "approved" โดย operator หลังผ่าน checklist
# Default: ว่าง (= not_approved) → exchange sync ยังคง disabled อยู่เสมอ
# ห้ามตั้งเป็น "approved" ก่อนผ่าน Phase M-0 permission checklist ครบ
EXCHANGE_MANUAL_APPROVAL=not_approved

# -------------------------------------------------------
# Phase M-0 Hard Rules:
#   - SHADOW_LIVE_ENABLED=true ได้เฉพาะหลัง operator approval
#   - EXCHANGE_READONLY_SYNC_ENABLED=true ได้เฉพาะหลัง operator approval
#   - ห้ามใส่ API key จริงก่อนได้รับ approval
#   - ห้าม expose BINGX_READONLY_* ไป client bundle
#   - ห้ามใช้ NEXT_PUBLIC_ กับ secret ใดๆ
# -------------------------------------------------------
